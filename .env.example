# Template for local dev. Copy to .env.local (gitignored) and fill in.
# For production, the real values live in .env.production (committed because
# Supabase anon keys are public-safe — security comes from RLS policies).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON=your-anon-key-here

# Override the base URL path during local dev or after custom-domain swap.
# Default in vite.config.ts is '/iglesia-bautista-biblica/' for GitHub Pages.
# Set to '/' after pointing the custom domain at the repo.
# VITE_BASE_PATH=/
